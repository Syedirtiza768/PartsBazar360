DATABASE_URL=postgresql://postgres:postgres@localhost:5432/partsbazar360
REDIS_URL=redis://localhost:6379
OPENSEARCH_NODE=http://localhost:9200

# RealTrack read-only Published Listings Reader. Keep credentials in the secret manager.
REALTRACK_API_URL=https://mhn.realtrackapp.com/api
REALTRACK_API_EMAIL=
REALTRACK_API_PASSWORD=
# Optional JSON override when stores change; the reader account cannot call GET /stores.
# Default seed uses Salvage Auto Parts + Blackline Auto Parts only.
REALTRACK_STORE_MANIFEST_JSON=
# Set true only if you intentionally want all 11 reader-connected stores.
SEED_ALL_REALTRACK_STORES=false

SEED_EBAY_STORES=true
SEED_SPREADSHEET_SELLERS=true
SEED_AUTH_USERS=true
SEED_AUTH_PASSWORD=ChangeMe123!
SEED_ADMIN_EMAIL=admin@partsbazar360.com
SEED_BUYER_EMAIL=buyer@partsbazar360.com
SEED_DEACTIVATE_LEGACY_SELLERS=true
AUTH_JWT_SECRET=change-me-in-production

# Stripe Checkout (hosted — card data never touches our servers). Use sandbox/test keys.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional; not required for hosted Checkout redirect flow.
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Buyer marketplace origin used for Stripe success/cancel URLs
BUYER_APP_URL=http://localhost:3000
# Legacy generic payment confirm (optional; Stripe webhook is preferred)
PAYMENT_WEBHOOK_SECRET=

# Empty means every listing. Set a positive value only for local development.
SEED_EBAY_LISTING_LIMIT=
SEED_DXB_FILE=
SEED_FEBEST_FILE=
SEED_DYNATRADE_FILE=
SEED_FEBEST_CURRENCY=
SEED_FEBEST_WEIGHT_UNIT=
SEED_FEBEST_DIMENSION_UNIT=
SEED_DYNATRADE_CURRENCY=USD
SEED_DXB_CURRENCY=USD
SEED_FEBEST_CURRENCY=USD
SEED_WIPE_MARKETPLACE_INVENTORY=true
# Always false for RealTrack: persist remote image URLs only (prefer ebay hosts).
SEED_DOWNLOAD_IMAGES=false
SEED_UPDATE_EXISTING=true
SEED_REMOVE_STALE_OFFERS=false
SEED_IMPORT_COMPATIBILITY=true
SEED_IMPORT_ALL_IMAGES=true
SEED_REPORT_PATH=seed-report.json
