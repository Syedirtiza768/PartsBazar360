DATABASE_URL=postgresql://postgres:postgres@localhost:5432/partsbazar360
REDIS_URL=redis://localhost:6379
OPENSEARCH_NODE=http://localhost:9200

# RealTrack read-only Published Listings Reader. Keep credentials in the secret manager.
REALTRACK_API_URL=https://mhn.realtrackapp.com/api
REALTRACK_API_EMAIL=
REALTRACK_API_PASSWORD=
# Optional JSON override when stores change; the reader account cannot call GET /stores.
REALTRACK_STORE_MANIFEST_JSON=

SEED_EBAY_STORES=true
SEED_SPREADSHEET_SELLERS=true
# Empty means every listing. Set a positive value only for local development.
SEED_EBAY_LISTING_LIMIT=
SEED_DXB_FILE=
SEED_FEBEST_FILE=
SEED_FEBEST_CURRENCY=
SEED_FEBEST_WEIGHT_UNIT=
SEED_FEBEST_DIMENSION_UNIT=
SEED_DOWNLOAD_IMAGES=false
SEED_UPDATE_EXISTING=true
SEED_REMOVE_STALE_OFFERS=false
SEED_IMPORT_COMPATIBILITY=true
SEED_IMPORT_ALL_IMAGES=true
SEED_REPORT_PATH=seed-report.json
