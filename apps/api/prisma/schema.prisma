generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sellers Seller[]
}

model Seller {
  id               String    @id @default(uuid())
  organizationId   String
  name             String
  storeId          String? // RealTrack store ID
  onboardingStatus String    @default("DRAFT")
  onboardingNotes  String?
  activatedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization         Organization                @relation(fields: [organizationId], references: [id])
  profile              SellerProfile?
  warehouses           Warehouse[]
  offers               SellerOffer[]
  sellerOrders         SellerOrder[]
  uploadJobs           SellerUploadJob[]
  pricingAssignments   SellerPricingAssignment[]
  agreementAcceptances SellerAgreementAcceptance[]
  sourceAccounts       SellerSourceAccount[]
  sourceRecords        SourceRecord[]
  reviewTasks          ReviewTask[]
}

model SellerProfile {
  id                  String    @id @default(uuid())
  sellerId            String    @unique
  accountType         String    @default("BUSINESS")
  legalName           String?
  tradingName         String?
  registrationNumber  String?
  taxId               String?
  website             String?
  phone               String?
  supportEmail        String?
  country             String?
  address             Json?
  complianceStatus    String    @default("NOT_STARTED")
  payoutStatus        String    @default("NOT_STARTED")
  fulfillmentSlaHours Int       @default(48)
  returnWindowDays    Int       @default(30)
  acceptsReturns      Boolean   @default(true)
  warrantyDays        Int       @default(0)
  supportedCategories String[]  @default([])
  supportedConditions String[]  @default([])
  shippingRegions     String[]  @default([])
  freightCapable      Boolean   @default(false)
  submittedAt         DateTime?
  approvedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)
}

model SellerAgreementAcceptance {
  id               String   @id @default(uuid())
  sellerId         String
  agreementType    String
  agreementVersion String
  acceptedByEmail  String
  acceptedAt       DateTime @default(now())
  metadata         Json?

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([sellerId, agreementType, agreementVersion])
}

model PricingPolicy {
  id            String    @id @default(uuid())
  code          String
  name          String
  version       Int       @default(1)
  mode          String
  percentRate   Float     @default(0)
  fixedFee      Float     @default(0)
  currency      String    @default("USD")
  category      String?
  minimumPrice  Float?
  maximumFee    Float?
  status        String    @default("DRAFT")
  priority      Int       @default(0)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  terms         Json?
  createdBy     String?
  approvedBy    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assignments  SellerPricingAssignment[]
  pricedOffers SellerOffer[]

  @@unique([code, version])
}

model SellerPricingAssignment {
  id              String    @id @default(uuid())
  sellerId        String
  pricingPolicyId String
  category        String?
  status          String    @default("ACTIVE")
  effectiveFrom   DateTime  @default(now())
  effectiveTo     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  seller        Seller        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  pricingPolicy PricingPolicy @relation(fields: [pricingPolicyId], references: [id])

  @@index([sellerId, category, status])
}

model Warehouse {
  id          String   @id @default(uuid())
  sellerId    String
  name        String
  location    String?
  externalKey String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seller    Seller      @relation(fields: [sellerId], references: [id])
  inventory Inventory[]

  @@unique([sellerId, externalKey])
}

model SellerSourceAccount {
  id                String    @id @default(uuid())
  sellerId          String
  sourcePlatform    String
  externalAccountId String
  marketplace       String?
  username          String?
  storeUrl          String?
  metadata          Json?
  lastSyncedAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  seller        Seller         @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  sourceRecords SourceRecord[]

  @@unique([sourcePlatform, externalAccountId])
}

model BrandMaster {
  id                    String   @id @default(uuid())
  canonicalName         String   @unique
  displayName           String
  brandTypes            String[] @default([])
  parentGroup           String?
  logoUrl               String?
  country               String?
  officialWebsite       String?
  isVehicleManufacturer Boolean  @default(false)
  isAftermarketBrand    Boolean  @default(false)
  suppliesGenuineOem    Boolean  @default(false)
  requiresManualReview  Boolean  @default(false)
  status                String   @default("ACTIVE")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  aliases     BrandAlias[]
  products    CanonicalPart[]
  partNumbers CatalogPartNumber[]
}

model BrandAlias {
  id         String   @id @default(uuid())
  brandId    String
  alias      String
  normalized String
  source     String?
  createdAt  DateTime @default(now())

  brand BrandMaster @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, normalized])
  @@index([normalized])
}

model CanonicalPart {
  id                       String   @id @default(uuid())
  title                    String
  brand                    String?
  manufacturer             String?
  category                 String?
  weight                   Float? // Weight in kg for shipping calculations
  oeNumbers                String[]
  fitmentFlags             String[]
  imageUrls                String[] @default([])
  listingUrl               String?
  ebayItemId               String?
  compatibility            Json?
  partSource               String   @default("OEM") // OEM, AFTERMARKET
  qualityTier              String   @default("USED") // NEW, USED, REFURBISHED, REMANUFACTURED, FOR_PARTS
  fitmentStatus            String   @default("NEEDS_REVIEW")
  fitmentConfidence        Float?
  normalizedTitle          String?
  description              String?
  partType                 String   @default("UNCLASSIFIED")
  primaryBrandId           String?
  manufacturerPartNumber   String?
  genuineOemPartNumber     String?
  dimensions               Json?
  position                 String?
  vehicleSystem            String?
  classificationStatus     String   @default("REVIEW_REQUIRED")
  classificationConfidence Float?
  classificationReason     String?
  completenessScore        Float?
  verificationStatus       String   @default("UNVERIFIED")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  offers         SellerOffer[]
  fitments       Fitment[]
  supportTickets SupportTicket[]
  uploadRows     SellerUploadRow[]
  primaryBrand   BrandMaster?        @relation(fields: [primaryBrandId], references: [id])
  partNumbers    CatalogPartNumber[]
  media          ProductMedia[]
  sourceRecords  SourceRecord[]
  salvageUnits   SalvageUnit[]
  redirectsFrom  CanonicalPartRedirect[] @relation("RedirectFrom")
  redirectsTo    CanonicalPartRedirect[] @relation("RedirectTo")
  reviewTasks    ReviewTask[]
  auditEvents    AuditEvent[]
}

model CatalogPartNumber {
  id                 String   @id @default(uuid())
  canonicalPartId    String
  displayNumber      String
  normalizedNumber   String
  numberType         String
  brandId            String?
  vehicleMakeId      String?
  source             String
  verificationStatus String   @default("UNVERIFIED")
  confidence         Float    @default(0)
  metadata           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  canonicalPart CanonicalPart @relation(fields: [canonicalPartId], references: [id], onDelete: Cascade)
  brand         BrandMaster?  @relation(fields: [brandId], references: [id])
  vehicleMake   VehicleMake?  @relation(fields: [vehicleMakeId], references: [id])

  @@unique([canonicalPartId, numberType, normalizedNumber, brandId, vehicleMakeId])
  @@index([normalizedNumber])
  @@index([vehicleMakeId, normalizedNumber])
}

model ProductMedia {
  id              String   @id @default(uuid())
  canonicalPartId String
  url             String
  normalizedUrl   String
  sourceUrl       String?
  sortOrder       Int      @default(0)
  isPrimary       Boolean  @default(false)
  isActualItem    Boolean  @default(false)
  mediaType       String   @default("IMAGE")
  importStatus    String   @default("IMPORTED")
  altText         String?
  createdAt       DateTime @default(now())

  canonicalPart CanonicalPart @relation(fields: [canonicalPartId], references: [id], onDelete: Cascade)

  @@unique([canonicalPartId, normalizedUrl])
}

model SellerOffer {
  id                   String    @id @default(uuid())
  sellerId             String
  canonicalPartId      String
  price                Float
  sellerBasePrice      Float?
  marketplaceFee       Float?
  sellerProceeds       Float?
  pricingPolicyId      String?
  pricingPolicyVersion Int?
  pricedAt             DateTime?
  currency             String    @default("AED")
  condition            String    @default("NEW")
  partSource           String    @default("OEM")
  qualityTier          String    @default("NEW")
  externalOfferId      String?
  status               String    @default("ACTIVE")
  sourceKey            String?   @unique
  sellerSku            String?
  sellerTitle          String?
  partType             String    @default("UNCLASSIFIED")
  moq                  Int       @default(1)
  leadTimeDays         Int?
  deliveryMethod       String?
  warranty             String?
  returnPolicy         String?
  sellerNotes          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  seller         Seller            @relation(fields: [sellerId], references: [id])
  pricingPolicy  PricingPolicy?    @relation(fields: [pricingPolicyId], references: [id])
  canonicalPart  CanonicalPart     @relation(fields: [canonicalPartId], references: [id])
  inventory      Inventory[]
  cartItems      CartItem[]
  orderItems     OrderItem[]
  supportTickets SupportTicket[]
  uploadRows     SellerUploadRow[]
  prices         OfferPrice[]
  sourceRecords  SourceRecord[]
  salvageUnits   SalvageUnit[]
}

model OfferPrice {
  id           String    @id @default(uuid())
  offerId      String
  currency     String
  amount       Decimal   @db.Decimal(18, 4)
  isPrimary    Boolean   @default(false)
  exchangeRate Decimal?  @db.Decimal(18, 8)
  rateSource   String?
  quotedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  offer SellerOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([offerId, currency])
}

model Inventory {
  id          String   @id @default(uuid())
  warehouseId String
  offerId     String
  quantity    Int      @default(0)
  status      String   @default("AVAILABLE")
  updatedAt   DateTime @updatedAt

  warehouse Warehouse   @relation(fields: [warehouseId], references: [id])
  offer     SellerOffer @relation(fields: [offerId], references: [id])

  @@unique([warehouseId, offerId])
}

model RawStagingListing {
  id              String   @id @default(uuid())
  sourceListingId String   @unique
  storeId         String
  marketplaceId   String?
  ebayItemId      String?
  ebayAccountId   String?
  offerId         String?
  title           String?
  sku             String?
  price           Float?
  currency        String?
  quantity        Int?
  status          String?
  listingUrl      String?
  imageUrls       String[] @default([])
  healthFlags     Json?
  compatibility   Json?
  rawPayload      Json
  processed       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model VehicleMake {
  id                String              @id @default(uuid())
  name              String              @unique
  canonicalName     String?
  displayName       String?
  manufacturerGroup String?
  regionalNames     Json?
  externalIds       Json?
  models            VehicleModel[]
  aliases           VehicleMakeAlias[]
  partNumbers       CatalogPartNumber[]
  donorVehicles     DonorVehicle[]
}

model VehicleMakeAlias {
  id            String   @id @default(uuid())
  vehicleMakeId String
  alias         String
  normalized    String   @unique
  region        String?
  source        String?
  createdAt     DateTime @default(now())

  vehicleMake VehicleMake @relation(fields: [vehicleMakeId], references: [id], onDelete: Cascade)
}

model VehicleModel {
  id          String              @id @default(uuid())
  makeId      String
  name        String
  generations VehicleGeneration[]
  make        VehicleMake         @relation(fields: [makeId], references: [id])
}

model VehicleGeneration {
  id             String                 @id @default(uuid())
  modelId        String
  name           String
  startYear      Int?
  endYear        Int?
  configurations VehicleConfiguration[]
  model          VehicleModel           @relation(fields: [modelId], references: [id])
}

model VehicleConfiguration {
  id              String    @id @default(uuid())
  generationId    String
  trim            String?
  engine          String?
  transmission    String?
  drivetrain      String?
  fuel            String?
  market          String?
  productionStart DateTime?
  productionEnd   DateTime?

  fitments     Fitment[]
  userVehicles UserVehicle[]
  generation   VehicleGeneration @relation(fields: [generationId], references: [id])
}

model Fitment {
  id                 String   @id @default(uuid())
  canonicalPartId    String
  vehicleConfigId    String
  evidenceLevel      String // A, B, C, D, E, F — derived from strongest evidence
  confidence         Float    @default(0.0)
  reviewer           String?
  source             String?
  verificationStatus String   @default("UNVERIFIED")
  reason             String?
  fitmentNotes       String?
  originalData       Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  canonicalPart CanonicalPart        @relation(fields: [canonicalPartId], references: [id])
  vehicleConfig VehicleConfiguration @relation(fields: [vehicleConfigId], references: [id])
  evidence      FitmentEvidence[]

  @@unique([canonicalPartId, vehicleConfigId])
}

model FitmentEvidence {
  id              String   @id @default(uuid())
  fitmentId       String
  evidenceType    String // MANUAL, EBAY_COMPATIBILITY, SELLER_DECLARED, OEM_CROSS_REFERENCE, VIN, TITLE_PARSE
  evidenceLevel   String // A-F
  confidence      Float    @default(0)
  source          String?
  sourceRecordId  String?
  originalValue   Json?
  normalizedValue Json?
  reason          String?
  verifiedBy      String?
  verifiedAt      DateTime?
  createdAt       DateTime @default(now())

  fitment Fitment @relation(fields: [fitmentId], references: [id], onDelete: Cascade)

  @@index([fitmentId, evidenceType])
}

model DonorVehicle {
  id               String   @id @default(uuid())
  makeId           String?
  model            String?
  modelYear        Int?
  trim             String?
  engine           String?
  engineCode       String?
  transmission     String?
  vinMasked        String?
  vinHash          String?
  mileage          Int?
  mileageUnit      String?
  donorStockNumber String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  make         VehicleMake?  @relation(fields: [makeId], references: [id])
  salvageUnits SalvageUnit[]
}

model SalvageUnit {
  id                  String   @id @default(uuid())
  canonicalPartId     String
  sellerOfferId       String
  donorVehicleId      String?
  originalOemNumber   String?
  conditionGrade      String?
  testedStatus        String?
  damageNotes         String?
  missingComponents   String[] @default([])
  warranty            String?
  dismantlingLocation String?
  shelfBin            String?
  identityMethod      String   @default("MANUAL")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  canonicalPart CanonicalPart @relation(fields: [canonicalPartId], references: [id])
  sellerOffer   SellerOffer   @relation(fields: [sellerOfferId], references: [id])
  donorVehicle  DonorVehicle? @relation(fields: [donorVehicleId], references: [id])

  @@unique([sellerOfferId])
}

model SourceRecord {
  id                       String    @id @default(uuid())
  sourceType               String
  sourcePlatform           String?
  sellerId                 String?
  sellerSourceAccountId    String?
  canonicalPartId          String?
  sellerOfferId            String?
  externalId               String?
  sourceFileName           String?
  sourceSheet              String?
  sourceRowNumber          Int?
  sourceKey                String    @unique
  rawPayload               Json
  transformations          Json?
  matchConfidence          Float?
  classificationConfidence Float?
  importedAt               DateTime  @default(now())
  lastSyncedAt             DateTime?

  seller              Seller?              @relation(fields: [sellerId], references: [id])
  sellerSourceAccount SellerSourceAccount? @relation(fields: [sellerSourceAccountId], references: [id])
  canonicalPart       CanonicalPart?       @relation(fields: [canonicalPartId], references: [id])
  sellerOffer         SellerOffer?         @relation(fields: [sellerOfferId], references: [id])
}

model User {
  id        String        @id @default(uuid())
  email     String        @unique
  name      String?
  role      String        @default("BUYER")
  vehicles  UserVehicle[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model UserVehicle {
  id              String   @id @default(uuid())
  userId          String
  vehicleConfigId String
  nickname        String?
  vin             String?
  registration    String?
  odometer        Int?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User                 @relation(fields: [userId], references: [id])
  vehicleConfig VehicleConfiguration @relation(fields: [vehicleConfigId], references: [id])
}

model Cart {
  id        String   @id @default(uuid())
  userId    String?
  sessionId String?  @unique // For guest carts
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items CartItem[]
}

model CartItem {
  id            String   @id @default(uuid())
  cartId        String
  sellerOfferId String
  quantity      Int
  addedAt       DateTime @default(now())

  cart        Cart        @relation(fields: [cartId], references: [id])
  sellerOffer SellerOffer @relation(fields: [sellerOfferId], references: [id])
}

model Order {
  id              String   @id @default(uuid())
  buyerId         String?
  totalAmount     Float
  currency        String   @default("AED")
  status          String   @default("PENDING_PAYMENT")
  shippingAddress Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sellerOrders   SellerOrder[]
  paymentIntent  PaymentIntent?
  supportTickets SupportTicket[]
}

model SellerOrder {
  id                  String   @id @default(uuid())
  parentOrderId       String
  sellerId            String
  subTotal            Float
  shippingTotal       Float
  marketplaceFeeTotal Float    @default(0)
  sellerProceedsTotal Float    @default(0)
  status              String   @default("AWAITING_PAYMENT")
  trackingNumber      String?
  carrier             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  parentOrder    Order           @relation(fields: [parentOrderId], references: [id])
  seller         Seller          @relation(fields: [sellerId], references: [id])
  items          OrderItem[]
  supportTickets SupportTicket[]
}

model OrderItem {
  id                   String  @id @default(uuid())
  sellerOrderId        String
  sellerOfferId        String
  quantity             Int
  unitPrice            Float
  sellerBaseUnitPrice  Float?
  marketplaceFeeUnit   Float?
  sellerProceedsUnit   Float?
  pricingPolicyId      String?
  pricingPolicyVersion Int?
  weight               Float?

  sellerOrder SellerOrder @relation(fields: [sellerOrderId], references: [id])
  sellerOffer SellerOffer @relation(fields: [sellerOfferId], references: [id])
}

model PaymentIntent {
  id         String   @id @default(uuid())
  orderId    String   @unique
  provider   String // generic, stripe, checkout.com
  externalId String?
  amount     Float
  currency   String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id])
}

model SellerUploadJob {
  id                   String    @id @default(uuid())
  sellerId             String
  fileName             String
  status               String    @default("PROCESSING")
  totalRows            Int       @default(0)
  processedRows        Int       @default(0)
  insertedRows         Int       @default(0)
  reviewRows           Int       @default(0)
  invalidRows          Int       @default(0)
  defaultPartSource    String    @default("OEM")
  defaultQualityTier   String    @default("USED")
  warnings             Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  completedAt          DateTime?
  fileChecksum         String?
  mimeType             String?
  sourceSheet          String?
  mapping              Json?
  defaultBrand         String?
  defaultCurrency      String?
  defaultDimensionUnit String?
  defaultWeightUnit    String?
  report               Json?
  /// IMMEDIATE = stage+commit in one pass (seed / legacy). STAGED = preview before commit.
  commitMode           String    @default("IMMEDIATE")
  catalogType          String? // GENUINE_OEM | AFTERMARKET | SALVAGE_OEM | MIXED | UNSURE
  preview              Json?
  detection            Json?

  seller      Seller            @relation(fields: [sellerId], references: [id])
  rows        SellerUploadRow[]
  reviewTasks ReviewTask[]

  @@unique([sellerId, fileChecksum])
}

model SellerUploadRow {
  id                       String   @id @default(uuid())
  uploadJobId              String
  rowNumber                Int
  status                   String   @default("IMPORTED")
  sku                      String?
  title                    String?
  brand                    String?
  category                 String?
  oemPartNumber            String?
  partSource               String   @default("OEM")
  qualityTier              String   @default("USED")
  condition                String   @default("USED")
  price                    Float?
  quantity                 Int      @default(1)
  currency                 String   @default("AED")
  imageUrls                String[] @default([])
  fitmentSummary           Json?
  reviewReasons            Json?
  message                  String?
  rawData                  Json
  canonicalPartId          String?
  sellerOfferId            String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  sourceKey                String?
  normalizedData           Json?
  classificationConfidence Float?
  classificationReason     String?
  matchConfidence          Float?
  matchCandidateId         String?
  matchExplanation         Json?
  suggestedPartType        String?
  stagedPayload            Json?

  uploadJob     SellerUploadJob @relation(fields: [uploadJobId], references: [id], onDelete: Cascade)
  canonicalPart CanonicalPart?  @relation(fields: [canonicalPartId], references: [id])
  sellerOffer   SellerOffer?    @relation(fields: [sellerOfferId], references: [id])

  @@unique([uploadJobId, rowNumber])
  @@index([status])
}

model CanonicalPartRedirect {
  id              String   @id @default(uuid())
  fromPartId      String
  toPartId        String
  reason          String?
  mergedBy        String?
  createdAt       DateTime @default(now())

  fromPart CanonicalPart @relation("RedirectFrom", fields: [fromPartId], references: [id])
  toPart   CanonicalPart @relation("RedirectTo", fields: [toPartId], references: [id])

  @@unique([fromPartId])
  @@index([toPartId])
}

model ReviewTask {
  id              String    @id @default(uuid())
  queueType       String
  status          String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, DISMISSED
  severity        String    @default("MEDIUM") // LOW, MEDIUM, HIGH, BLOCKING
  title           String
  description     String?
  entityType      String?
  entityId        String?
  sellerId        String?
  uploadJobId     String?
  canonicalPartId String?
  payload         Json?
  confidence      Float?
  assignedTo      String?
  resolvedBy      String?
  resolution      String?
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  seller        Seller?          @relation(fields: [sellerId], references: [id])
  uploadJob     SellerUploadJob? @relation(fields: [uploadJobId], references: [id])
  canonicalPart CanonicalPart?   @relation(fields: [canonicalPartId], references: [id])

  @@index([queueType, status])
  @@index([sellerId, status])
  @@index([uploadJobId])
}

model AuditEvent {
  id              String   @id @default(uuid())
  action          String
  entityType      String
  entityId        String
  actorType       String   @default("SYSTEM") // SYSTEM, SELLER, ADMIN, SEED
  actorId         String?
  source          String?
  reason          String?
  confidence      Float?
  originalValue   Json?
  normalizedValue Json?
  metadata        Json?
  canonicalPartId String?
  createdAt       DateTime @default(now())

  canonicalPart CanonicalPart? @relation(fields: [canonicalPartId], references: [id])

  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@index([canonicalPartId])
}

model SearchOutbox {
  id          String    @id @default(uuid())
  entityType  String    @default("CanonicalPart")
  entityId    String
  operation   String    @default("UPSERT") // UPSERT, DELETE
  payload     Json?
  status      String    @default("PENDING") // PENDING, PROCESSING, DONE, FAILED
  attempts    Int       @default(0)
  lastError   String?
  availableAt DateTime  @default(now())
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, availableAt])
  @@index([entityId])
}

model SupportTicket {
  id              String   @id @default(uuid())
  orderId         String?
  sellerOrderId   String?
  canonicalPartId String?
  sellerOfferId   String?
  customerName    String?
  customerEmail   String
  category        String
  subject         String
  message         String
  status          String   @default("OPEN")
  priority        String   @default("NORMAL")
  internalNotes   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  order         Order?         @relation(fields: [orderId], references: [id])
  sellerOrder   SellerOrder?   @relation(fields: [sellerOrderId], references: [id])
  canonicalPart CanonicalPart? @relation(fields: [canonicalPartId], references: [id])
  sellerOffer   SellerOffer?   @relation(fields: [sellerOfferId], references: [id])
}
